# Copy to .env.local and fill in. NEVER commit the real file.

# BSC RPC for server-side reads (an archive node is best for old locks).
RPC_URL=https://bsc-dataseed.binance.org/

# Etherscan unified API key (chainid=56 = BSC). Used by /api/stats discovery.
ETHERSCAN_API_KEY=

# Optional override of the API base. Default = Etherscan v2 multichain (BSC).
# API_BASE=https://api.etherscan.io/v2/api?chainid=56

# DXsale deployer/factory whose created contracts are treated as candidate locks.
FACTORY=

# Current BNB price (USD) for value estimates. Swap for a live feed later.
BNB_USD=600

# ---- Optional tip + referral (client-side; NEXT_PUBLIC_ is exposed in browser) ----
# Public address that receives optional tips. Leave blank to disable tipping.
NEXT_PUBLIC_TIP_ADDRESS=
# Suggested tip, in basis points of recovered value (1000 = 10%).
NEXT_PUBLIC_TIP_BPS=1000
# Referrer's share of a tip, in basis points (5000 = 50% of the tip).
NEXT_PUBLIC_REFERRAL_SHARE_BPS=5000
# BNB price for the client-side suggested-tip calc.
NEXT_PUBLIC_BNB_USD=600
