# Copy to .env and fill in. NEVER commit the real file.
# Foundry auto-loads .env for deploy; Next.js loads it for the app.

# BSC RPC for server-side reads + deploy (an archive node is best for old locks).
RPC_URL=https://bsc-dataseed.binance.org/

# Etherscan unified API key (chainid=56 = BSC). Used by scripts/index-locks.mjs
# and by Foundry for contract verification.
# Free key: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ---- Contract deploy (Foundry) ----
# Deployer private key (the fee/deploy wallet). Copy from wallet.json. NEVER commit.
PRIVATE_KEY=
# Fee + deploy wallet (public address).
FEE_WALLET=

# Optional override of the API base. Default = Etherscan v2 multichain (BSC).
# API_BASE=https://api.etherscan.io/v2/api?chainid=56

# DXsale presale factory whose created contracts are the locks. This is the verified
# default (it created the RTL lock; ~5,015 byte-identical locks share its template).
FACTORY=0xc5fe280422117461af9b953da413e9627e3b9a40

# Current BNB price (USD) for value estimates. Swap for a live feed later.
BNB_USD=600

# ---- Recovery contract (client-side; NEXT_PUBLIC_ is exposed in browser) ----
# Deployed RescueExecutor (EIP-7702) address. Leave blank until deployed + audited;
# the recovery page then shows a "not live yet" notice. The 15% fee + 10% referral
# split are HARDCODED in the contract (FEE_BPS / REFERRAL_BPS), not configurable here.
NEXT_PUBLIC_RESCUE_EXECUTOR=
# BNB price for client-side value/fee display.
NEXT_PUBLIC_BNB_USD=600
# Optional tip/support address (defaults to FEE_WALLET if unset).
NEXT_PUBLIC_TIP_ADDRESS=
